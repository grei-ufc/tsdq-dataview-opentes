{
  "Tensão": {
    "_instrucao_equipe": "Aceita formato nativo do OpenDSS ou limpo. Padrão: (Bus-){NOME}-V{FASE}_pu",
    "_exemplo": "Bus-UNTRS_039281-V1_pu ou UNTRS_039281-V1_pu",
    "regex": "(?:Bus-)?(.+?)-V(\\d+)_(pu|kV|V)",
    "prefixo": "V",
    "tem_fase": true
  },
  "Corrente (A)": {
    "_instrucao_equipe": "Aceita formato nativo do OpenDSS ou limpo. Padrão: (Line-){NOME}-I{FASE}_A",
    "_exemplo": "Line-LT_500_XINGU-I2_A ou LT_500_XINGU-I2_A",
    "regex": "(?:Line-)?(.+?)-I(\\d+)_A",
    "prefixo": "I",
    "tem_fase": true
  },
  "Ângulo de Corrente (°)": {
    "_instrucao_equipe": "Aceita formato nativo do OpenDSS ou limpo. Padrão: (Line-){NOME}-I{FASE}_ang",
    "_exemplo": "Line-LT_500_XINGU-I2_ang ou LT_500_XINGU-I2_ang",
    "regex": "(?:Line-)?(.+?)-I(\\d+)_ang",
    "prefixo": "I",
    "tem_fase": true
  },
  "Taps dos Reguladores": {
    "_instrucao_equipe": "Aceita formato nativo do OpenDSS ou limpo. Padrão: (RegControl-){NOME}-tap",
    "_exemplo": "RegControl-creg1a-tap ou creg1a-tap",
    "regex": "(?:RegControl-)?(.+?)-tap",
    "prefixo": "Tap",
    "tem_fase": false
  },
  "Potência do Gerador (MW)": {
    "_instrucao_equipe": "Aceita formato nativo do OpenDSS ou limpo. Padrão: (Generator-){NOME}-P_MW",
    "_exemplo": "Generator-Gen_0-P_MW ou Gen_0-P_MW",
    "regex": "(?:Generator-)?(.+?)-P_MW",
    "prefixo": "P",
    "tem_fase": false
  },
  "Irradiância Solar (DNI)": {
    "_instrucao_equipe": "Padrão: {NOME}-DNI",
    "_exemplo": "Sensor_01-DNI ou CSV-0.csv-0-DNI",
    "regex": "(.+?)-DNI",
    "prefixo": "DNI",
    "tem_fase": false
  },
  "Potência Fotovoltaica": {
    "_instrucao_equipe": "Padrão: {NOME}-P_gen",
    "_exemplo": "PV-0.PV_0-P_gen ou Usina_Solar-P_gen",
    "regex": "(.+?)-P_gen",
    "prefixo": "P",
    "tem_fase": false
  },
  "Potência Ativa da Rede (MW)": {
    "_instrucao_equipe": "Prefixo Grid opcional. Padrão: (Grid-{ID}-){NOME}-p_MW",
    "_exemplo": "Grid-0.0-LV2.101 Bus 19-p_MW ou LV2.101 Bus 19-p_MW",
    "regex": "(?:Grid-[\\w.-]+-)?(.+?)-p_MW",
    "prefixo": "P",
    "tem_fase": false
  },
  "Potência Reativa da Rede (MVAr)": {
    "_instrucao_equipe": "Prefixo Grid opcional. Padrão: (Grid-{ID}-){NOME}-q_MVar",
    "_exemplo": "Grid-0.0-LV2.101 Bus 28-q_MVar ou LV2.101 Bus 28-q_MVar",
    "regex": "(?:Grid-[\\w.-]+-)?(.+?)-q_MVar",
    "prefixo": "Q",
    "tem_fase": false
  },
  "_Configuracoes_Geograficas": {
    "_instrucao_equipe": "Defina as colunas exatas que o seu ficheiro de coordenadas vai ter",
    "coluna_elemento": "Barra",
    "coluna_x": "X",
    "coluna_y": "Y"
  }
}